################################################################################
#  fs-enrs Backend — Environment Configuration
#  Copy to .env and fill in the ★ values
################################################################################

NODE_ENV=development
PORT=4100

# ★ Database — new fs_enrs database (separate from fs_cc)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fs_enrs
DB_USER=fs_enrs
DB_PASSWORD=changeme
DB_SSL=false

# ★ JWT secrets — generate two separate random 32+ char strings
JWT_ACCESS_SECRET=REPLACE_WITH_RANDOM_STRING_access_32_chars
JWT_REFRESH_SECRET=REPLACE_WITH_RANDOM_STRING_refresh_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ★ FreeSWITCH ESL — same instance as fs-cc
ESL_HOST=127.0.0.1
ESL_PORT=8021
ESL_PASSWORD=ClueCon
ESL_RECONNECT_MS=3000

# ★ Internal API key — shared secret between backend and FreeSWITCH Lua scripts
# Must match FS_INTERNAL_KEY set on the FreeSWITCH server (vars.xml or systemd env)
# Generate: openssl rand -hex 32
INTERNAL_API_KEY=REPLACE_WITH_RANDOM_HEX_32

# ENS originate mode — how the backend dials contacts
# 'user'    = internal extensions only (lab mode, no SIP trunk needed)
# 'gateway' = external SIP gateway (production)
ENS_ORIGINATE_MODE=user

# CORS — frontend origins (comma-separated)
CORS_ORIGIN=http://localhost:8100

# File uploads
UPLOAD_DIR=./uploads
UPLOAD_MAX_MB=50

# Seed script defaults (only used by: node src/db/seed.js)
SEED_ADMIN_EMAIL=admin@enrs.local
SEED_ADMIN_PASSWORD=Admin@12345
