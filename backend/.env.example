################################################################################
#  fs-enrs Backend — Environment Configuration
#  Copy to .env and fill in the ★ values
################################################################################

NODE_ENV=development
PORT=4100

# ★ Database — new fs_enrs database (separate from fs_cc)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fs_enrs
DB_USER=fs_enrs
DB_PASSWORD=changeme
DB_SSL=false

# ★ JWT secrets — generate two separate random 32+ char strings
JWT_ACCESS_SECRET=REPLACE_WITH_RANDOM_STRING_access_32_chars
JWT_REFRESH_SECRET=REPLACE_WITH_RANDOM_STRING_refresh_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ★ FreeSWITCH ESL — same instance as fs-cc
ESL_HOST=127.0.0.1
ESL_PORT=8021
ESL_PASSWORD=ClueCon
ESL_RECONNECT_MS=3000

# ★ Internal API key — shared secret between backend and FreeSWITCH Lua scripts
# Must match FS_INTERNAL_KEY set on the FreeSWITCH server (vars.xml or systemd env)
# Generate: openssl rand -hex 32
INTERNAL_API_KEY=REPLACE_WITH_RANDOM_HEX_32

# ENS originate mode — how the backend dials contacts
# 'user'    = internal extensions only (lab mode, no SIP trunk needed)
# 'gateway' = external SIP gateway (production)
ENS_ORIGINATE_MODE=user

# ── ENRS IVR Deployment ───────────────────────────────────────────────────────
# URL that FreeSWITCH Lua scripts use to reach THIS backend.
# Usually http://127.0.0.1:<PORT> when FS and backend are on the same server.
# If they are on different servers, use the backend's LAN IP.
ENRS_API_URL=http://127.0.0.1:4100

# TTS engine string for FreeSWITCH speak application  (engine|voice)
# mod_flite:   flite|kal   (open-source, install: apt-get install freeswitch-mod-flite)
# mod_espeak:  espeak|default
# mod_unimrcp: unimrcp|<profile>
FS_TTS_ENGINE=flite|kal

# Audio upload directory (local staging before copy to FS_SOUND_DIR/enrs/)
UPLOAD_DIR=./uploads
UPLOAD_MAX_MB=50
#To check the freeswitch paths, run the following commands in the FreeSWITCH CLI:
#fs_cli -x "global_getvar conf_dir"
#fs_cli -x "global_getvar script_dir"
#fs_cli -x "global_getvar recordings_dir"
#fs_cli -x "global_getvar sounds_dir"
#fs_cli -x "global_getvar storage_dir"
#fs_cli -x "global_getvar db_dir"
#fs_cli -x "global_getvar log_dir"
# ── FreeSWITCH filesystem paths ───────────────────────────────────────────────
# Set these to match your FreeSWITCH installation.
# Leave unset to use the defaults (Debian/Ubuntu package layout).
#
# FS_BASE_DIR       — root share dir   (default: /usr/share/freeswitch)
# FS_CONF_DIR       — conf/            (default: /etc/freeswitch)
# FS_DIALPLAN_DIR   — conf/dialplan    (default: /etc/freeswitch/dialplan)
# FS_DIRECTORY_DIR  — conf/directory   (default: /etc/freeswitch/directory)
# FS_SIP_PROFILE_DIR— conf/sip_profiles(default: /etc/freeswitch/sip_profiles)
# FS_SCRIPT_DIR     — scripts/         (default: /usr/share/freeswitch/scripts)
# FS_SOUND_DIR      — sounds/          (default: /usr/share/freeswitch/sounds)
# FS_RECORDING_DIR  — recordings/      (default: /var/lib/freeswitch/recordings)
# FS_STORAGE_DIR    — storage/         (default: /var/lib/freeswitch/storage)
# FS_DB_DIR         — db/              (default: /var/lib/freeswitch/db)
# FS_LOG_DIR        — log/             (default: /var/log/freeswitch)
#
# ★ Uncomment and set any that differ from the defaults:
# FS_BASE_DIR=/usr/share/freeswitch
# FS_CONF_DIR=/etc/freeswitch
# FS_SCRIPT_DIR=/usr/share/freeswitch/scripts
# FS_RECORDING_DIR=/var/lib/freeswitch/recordings
################################################################################
# FreeSWITCH Installation (Dabin Development Server)
################################################################################

# Root installation
FS_BASE_DIR=/opt/freeswitch

################################################################################
# FreeSWITCH Configuration
################################################################################

FS_CONF_DIR=/opt/freeswitch/etc/freeswitch
FS_DIALPLAN_DIR=/opt/freeswitch/etc/freeswitch/dialplan
FS_DIRECTORY_DIR=/opt/freeswitch/etc/freeswitch/directory
FS_SIP_PROFILE_DIR=/opt/freeswitch/etc/freeswitch/sip_profiles

################################################################################
# FreeSWITCH Lua Scripts
################################################################################

FS_SCRIPT_DIR=/opt/freeswitch/share/freeswitch/scripts

################################################################################
# FreeSWITCH Sounds
################################################################################

FS_SOUND_DIR=/opt/freeswitch/share/freeswitch/sounds

################################################################################
# FreeSWITCH Recordings
################################################################################

FS_RECORDING_DIR=/opt/freeswitch/var/lib/freeswitch/recordings

################################################################################
# FreeSWITCH Storage
################################################################################

FS_STORAGE_DIR=/opt/freeswitch/var/lib/freeswitch/storage

################################################################################
# FreeSWITCH Database
################################################################################

FS_DB_DIR=/opt/freeswitch/var/lib/freeswitch/db

################################################################################
# FreeSWITCH Logs
################################################################################

FS_LOG_DIR=/opt/freeswitch/var/log/freeswitch
# CORS — frontend origins (comma-separated)
CORS_ORIGIN=http://localhost:8100

# File uploads
UPLOAD_DIR=./uploads
UPLOAD_MAX_MB=50

# Seed script defaults (only used by: node src/db/seed.js)
SEED_ADMIN_EMAIL=admin@enrs.local
SEED_ADMIN_PASSWORD=Admin@12345
