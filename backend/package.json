{
  "name": "fs-enrs-backend",
  "version": "1.0.0",
  "description": "ENS/ERS Emergency Notification and Response System — Backend API",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start":   "node server.js",
    "dev":     "node --watch server.js",
    "migrate": "node src/db/migrate.js",
    "seed":    "node src/db/seed.js",
    "test":    "vitest run",
    "test:watch": "vitest",
    "verify:lua":       "node scripts/lua-syntax-check.js",
    "verify:xml":       "node scripts/xml-structural-check.js",
    "verify:contracts": "node ../scripts/verify-api-contracts.js",
    "verify:all":       "npm run verify:lua && npm run verify:xml && npm run verify:contracts && npm test",
    "lint":    "eslint src server.js"
  },
  "dependencies": {
    "bcryptjs":          "^2.4.3",
    "cookie-parser":     "^1.4.6",
    "cors":              "^2.8.5",
    "csv-parse":         "^5.5.6",
    "dotenv":            "^16.4.5",
    "modesl":            "^1.2.1",
    "express":           "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet":            "^7.1.0",
    "jsonwebtoken":      "^9.0.2",
    "multer":            "^1.4.5-lts.1",
    "pg":                "^8.12.0",
    "socket.io":         "^4.7.5",
    "uuid":              "^10.0.0",
    "zod":               "^3.23.8",
    "fast-xml-parser":   "^4.4.1"
  },
  "devDependencies": {
    "nodemon":    "^3.1.4",
    "vitest":     "^1.6.0",
    "supertest":  "^7.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint":     "^9.9.0",
    "@eslint/js": "^9.9.0"
  },
  "engines": { "node": ">=20" }
}
